# Secrets for the interstellar gateway, injected as environment variables.
# Copy to `.env` (which is gitignored) and fill in only what your targets need.
# Reference these names from config.yaml via `password_env:` / `authkey_env:`.

# Password for an SSH target whose config sets `password_env: INTERSTELLAR_REMOTE_PASSWORD`
# INTERSTELLAR_REMOTE_PASSWORD=

# Tailscale auth key for a tailscale target whose config sets `authkey_env: TS_AUTHKEY`
# (requires the tailscale wormhole — see the wormholes repo)
# TS_AUTHKEY=
